# Copy to `.env` locally. In Vercel: Project Settings → Environment Variables (same names).

# --- Required (Supabase) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# --- Optional (Web Push; leave empty to skip push subscription in the app) ---
# Generate keys: npx web-push generate-vapid-keys
# Set VITE_VAPID_PUBLIC_KEY locally and in hosting env (e.g. Vercel).
VITE_VAPID_PUBLIC_KEY=
